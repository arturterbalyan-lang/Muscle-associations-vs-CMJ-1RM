# ---- 9. Residual-vs-Fitted Plots --------------------------------------------

if (exists("model_cmj") & exists("model_1rm")) {
  par(mfrow = c(1, 2), mar = c(4, 4, 3, 1))
  
  plot(fitted(model_cmj), residuals(model_cmj),
       xlab = "Fitted values", ylab = "Residuals",
